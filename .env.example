# ─── Backend ──────────────────────────────────────────────────────────────────
# Server-side: used by Next.js rewrites to proxy /api/backend/* → your backend
BACKEND_URL=https://your-backend.com

# ─── Client-side (must be prefixed NEXT_PUBLIC_) ──────────────────────────────
# WebSocket endpoint — must point DIRECTLY to backend (bypasses Vercel proxy)
NEXT_PUBLIC_WS_URL=https://your-backend.com/ws

# Google OAuth redirect — full URL including path
NEXT_PUBLIC_GOOGLE_AUTH_URL=https://your-backend.com/oauth2/authorization/google
